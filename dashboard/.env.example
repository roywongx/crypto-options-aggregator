# Crypto Options Aggregator 配置示例
# 复制此文件为 .env 并填入实际值

# 运行环境: development | production
# development: 本地访问免验证，允许本地跨域
# production: 强制 API Key 验证，禁止未配置跨域
DASHBOARD_ENV=development

# API 认证密钥
# - 本地访问 (127.0.0.1/localhost) 始终免验证
# - 远程访问必须提供此 Key (通过 X-API-Key Header)
# - 生产环境必须设置，否则拒绝远程访问
DASHBOARD_API_KEY=

# 数据库路径 (留空使用默认路径)
DASHBOARD_DB_PATH=

# CORS 允许的源 (逗号分隔)
# 生产环境未设置则禁止所有跨域
# 开发环境默认: http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Binance API Key (清算热力图等需要签名的端点)
# ⚠️ 高度敏感 — 请勿提交到 Git 或分享给任何人
# 在 Binance 创建: https://www.binance.com/zh-CN/my/settings/api-management
# 建议只开读取权限，不要开交易/提现权限
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Deribit API Key (获取个人持仓、账户余额等)
# ⚠️ 高度敏感 — 请勿提交到 Git 或分享给任何人
# 在 Deribit 创建: https://www.deribit.com/account/BTC
# Deribit 使用 client_id + client_secret (OAuth2)
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# 服务端口
PORT=8000
